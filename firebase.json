{
  "projects": {
    "default": "misc-ionic-mobile-app"
  },
  "targets": {
    "misc-ionic-mobile-app": {
      "hosting": {
        "app": [
          "web"
        ]
      },
      "storage": {
        "default": "misc-ionic-mobile-app.firebasestorage.app"
      }
    }
  },
  "hosting": [
    {
      "target": "app",
      "public": "www/browser",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "appDistribution": {
    "app": "1:689975823115:android:36477be5ac6ceac56b300e",
    "releaseNotes": "Release notes can be managed via Firebase Console or in deployment scripts"
  }
}
